{
  "name": "llmrix-devtool",
  "version": "0.0.1",
  "description": "An AI coding assistant that runs as an [ACP] server over stdio. Works with **Zed**, **JetBrains IDEs**, and any other ACP-compatible client.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/llmrix/llmrix-devtool.git"
  },
  "keywords": [
    "ai",
    "agent",
    "coding-assistant",
    "acp",
    "zed",
    "jetbrains"
  ],
  "author": "llmrix",
  "homepage": "https://github.com/llmrix/llmrix-devtool#readme",
  "bugs": {
    "url": "https://github.com/llmrix/llmrix-devtool/issues"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "dist/",
    "assets/",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "bin": {
    "llmrix-devtool": "dist/cli.js"
  },
  "scripts": {
    "build": "npm run clean && esbuild src/cli.ts src/index.ts src/scripts/postinstall.ts --bundle --minify --platform=node --format=esm --outdir=dist --packages=external && node scripts/copy-templates.mjs",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "dev:repl": "node scripts/dev-repl.mjs",
    "start": "node dist/cli.js",
    "postinstall": "node dist/scripts/postinstall.js || true"
  },
  "dependencies": {
    "deepagents": "^1.9.0",
    "deepagents-acp": "^0.1.8",
    "@langchain/anthropic": "^1.3.26",
    "@langchain/openai": "^1.4.1",
    "@langchain/core": "^1.1.40",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "esbuild": "^0.20.0"
  }
}